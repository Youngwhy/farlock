#!/bin/bash
# farlock — runtime CLI for the iPhone Proximity Auto-Lock agent.
#
# Installed by install.sh (symlinked into a directory on your PATH).
# All commands operate on the currently-installed config at
# ~/Library/Application Support/farlock/config.json.

set -euo pipefail

CONFIG_DIR="$HOME/Library/Application Support/farlock"
CONFIG_FILE="$CONFIG_DIR/config.json"
LOG_FILE="$HOME/Library/Logs/farlock.log"
LAUNCH_AGENT="$HOME/Library/LaunchAgents/com.farlock.plist"
AGENT_LABEL="com.farlock"

# These paths are filled in at install time by install.sh so the CLI knows
# where to find install assets for re-targeting.
INSTALL_DIR="${PROXIMITY_LOCK_INSTALL_DIR:-__INSTALL_DIR__}"
AGENT_BIN="$INSTALL_DIR/scanner/.build/release/Farlock"

GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
RED=$'\033[0;31m'
BOLD=$'\033[1m'
NC=$'\033[0m'

die()   { printf "%s[error]%s %s\n" "$RED" "$NC" "$*" >&2; exit 1; }
note()  { printf "%s[ok]%s    %s\n" "$GREEN" "$NC" "$*"; }
warn()  { printf "%s[warn]%s  %s\n" "$YELLOW" "$NC" "$*"; }

require_config() {
  [ -f "$CONFIG_FILE" ] || die "config not found at $CONFIG_FILE. Run install.sh first."
}

reload_agent() {
  if [ -f "$LAUNCH_AGENT" ]; then
    launchctl kickstart -k "gui/$(id -u)/$AGENT_LABEL" 2>/dev/null || true
  fi
}

usage() {
  cat <<EOF
Usage: farlock <command> [args]

Commands:
  status                       Show agent state + key config values
  target                       Re-run the target picker
  away-rssi                    Show the away (lock) RSSI threshold (dBm)
  away-rssi DBM                Change the away threshold (e.g. -60)
  rearm-rssi                   Show the rearm (cancel) RSSI threshold (dBm)
  rearm-rssi DBM               Change the rearm threshold (e.g. -55)
  list-paired                  Print paired Bluetooth devices
  logs                         Stream ~/Library/Logs/farlock.log
  reload                       Kickstart the LaunchAgent
  uninstall                    Remove the agent, config, and this CLI
  -h, --help                   This help

Thresholds are raw RSSI (dBm, negative). Less-negative = closer. Watch
'farlock logs' to see the ewma= value at the positions where you want the
lock to fire and rearm, then set those numbers. rearm-rssi must be strictly
greater than away-rssi (closer); at least 5 dB gap (8-12 dB for more margin).

Config file: $CONFIG_FILE
EOF
}

# ---------- status -----------------------------------------------------------

cmd_status() {
  require_config
  local pid
  pid=$(pgrep -x Farlock || true)
  if [ -n "$pid" ]; then
    note "agent running (pid $pid)"
  else
    warn "agent not running"
  fi

  # Runtime state — parsed from the tail of the log.
  python3 - "$LOG_FILE" <<'PY'
import os, re, sys, time

path = sys.argv[1]
if not os.path.exists(path):
    print()
    print("Runtime state: (log file not present yet — agent may be starting up or stopped)")
    sys.exit(0)

try:
    with open(path, "rb") as f:
        f.seek(0, os.SEEK_END)
        size = f.tell()
        f.seek(max(0, size - 64 * 1024))
        tail = f.read().decode("utf-8", errors="replace").splitlines()
except Exception as e:
    print()
    print(f"Runtime state: (failed to read log: {e})")
    sys.exit(0)

target_match = None
last_tick = None
last_state_event = None
last_watchdog = None

for line in tail:
    if "target matched:" in line:
        target_match = line
    elif " tick: " in line:
        last_tick = line
    elif any(s in line for s in (
        "Away threshold crossed", "back in range", "scheduleLock",
        "commitLock", "cancelLock", "Signal lost",
        "Trusted Wi-Fi bypass", "system will sleep", "system did wake",
        "screen locked", "screen unlocked", "lock watchdog",
    )):
        last_state_event = line

def ts_prefix(line):
    # log format: "YYYY-MM-DD HH:MM:SS message"
    m = re.match(r"^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})", line)
    return m.group(1) if m else None

def age_seconds(line):
    ts = ts_prefix(line)
    if not ts: return None
    try:
        t = time.mktime(time.strptime(ts, "%Y-%m-%d %H:%M:%S"))
        return max(0, int(time.time() - t))
    except Exception:
        return None

def fmt_age(s):
    if s is None: return "?"
    if s < 60:    return f"{s}s ago"
    if s < 3600:  return f"{s//60}m {s%60}s ago"
    return f"{s//3600}h {(s%3600)//60}m ago"

print()
print("Runtime state:")
if target_match:
    # e.g. "2026-04-24 10:20:30 target matched: UUID name=iPhone mac=AA:BB..."
    m = re.search(r"target matched:\s*(.*)$", target_match)
    detail = m.group(1) if m else target_match
    print(f"  target matched:  {detail}")
else:
    print("  target matched:  never (no match seen in recent logs)")
    print("                   -> check targetName/targetUuid/targetMacAddr match your actual iPhone")

if last_tick:
    # "2026-04-24 10:20:30 tick: rssi=-55 name=iPhone ewma=-56.2 away<=-60 rearm>=-55"
    age = fmt_age(age_seconds(last_tick))
    m = re.search(r"tick:\s*(.*)$", last_tick)
    detail = m.group(1) if m else last_tick
    print(f"  last sample:     {detail}  ({age})")
else:
    print("  last sample:     none (no RSSI received yet)")

if last_state_event:
    age = fmt_age(age_seconds(last_state_event))
    # strip timestamp prefix for compactness
    body = re.sub(r"^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\s*", "", last_state_event)
    print(f"  last event:      {body}  ({age})")
PY

  python3 - "$CONFIG_FILE" <<'PY'
import json, sys

# (key, display-name, unit, one-line description)
FIELDS = [
    ("targetName",               "target.name",          "",   "iPhone's Bluetooth name"),
    ("targetMacAddr",            "target.mac",           "",   "iPhone's MAC address"),
    ("targetUuid",               "target.uuid",          "",   "CBPeripheral UUID (most stable identifier)"),
    ("awayRssi",                 "awayRssi",             "dBm","If smoothed RSSI drops to/below this, start the away-dwell timer (more negative = farther)"),
    ("rearmRssi",                "rearmRssi",            "dBm","If smoothed RSSI climbs to/above this, cancel countdown and clear away state (must be > awayRssi)"),
    ("awayDwellSeconds",         "awayDwell",            "s",  "Away state must persist this long before the warn overlay appears"),
    ("signalLostTimeoutSeconds", "signalLostTimeout",    "s",  "No valid RSSI sample for this long -> treated as 'signal lost' (triggers lock)"),
    ("warnBeforeLockSeconds",    "warnBeforeLock",       "s",  "Countdown length shown in the warn overlay before the actual lock"),
    ("warnCancelCooldownSeconds","warnCancelCooldown",   "s",  "After Esc cancel, suppress re-locking for this long (cooldown)"),
    ("lockAttemptCooldownSeconds","lockAttemptCooldown", "s",  "After a lock attempt, suppress the next attempt for this long (debounce)"),
    ("unlockCooldownSeconds",    "unlockCooldown",       "s",  "After a manual unlock, suppress re-locking for this long (cooldown)"),
    ("ewmaAlpha",                "ewmaAlpha",            "",   "RSSI smoothing factor 0-1 (higher = snappier, lower = more noise-resistant)"),
    ("activeMode",               "activeMode",           "",   "If true, connect to the device and poll readRSSI() every 2s"),
    ("trustedWifiSSIDs",         "trustedWifiSSIDs",     "",   "Disable auto-lock while connected to any listed SSID"),
    ("logFile",                  "logFile",              "",   "Log file path"),
]

with open(sys.argv[1]) as f:
    c = json.load(f)

key_w = max(len(f[1]) for f in FIELDS)
val_w = 24
print()
print("Config:")
for key, label, unit, desc in FIELDS:
    v = c.get(key)
    if isinstance(v, list):
        shown = ", ".join(v) if v else "(none)"
    elif v is None:
        shown = "null"
    elif isinstance(v, bool):
        shown = "true" if v else "false"
    else:
        shown = str(v)
    if unit and v is not None and not isinstance(v, (list, bool)):
        shown = f"{shown} {unit}"
    print(f"  {label.ljust(key_w)}  {shown.ljust(val_w)}  — {desc}")
PY
}

# ---------- show / set distance ---------------------------------------------

patch_cfg_num() {
  # patch_cfg_num <json_key> <value>
  require_config
  python3 - "$CONFIG_FILE" "$1" "$2" <<'PY'
import json, sys
path, key, val = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path) as f: cfg = json.load(f)
old = cfg.get(key)
cfg[key] = float(val) if "." in val else int(val)
with open(path, "w") as f: json.dump(cfg, f, indent=2)
print(f"{key}: {old} → {cfg[key]}")
PY
}

show_cfg() {
  # show_cfg <json_key> <unit>
  require_config
  python3 - "$CONFIG_FILE" "$1" "${2:-}" <<'PY'
import json, sys
path, key, unit = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path) as f: cfg = json.load(f)
v = cfg.get(key)
print(f"{key}: {v}{' ' + unit if unit else ''}")
PY
}

set_rssi() {
  # set_rssi <which> <value>  where which = "away" or "rearm"
  # RSSI is negative; less-negative = closer. Enforces rearm > away so the
  # hysteresis band is non-zero (rearm must be strictly closer than away).
  require_config
  python3 - "$CONFIG_FILE" "$1" "$2" <<'PY'
import json, sys
path, which, val = sys.argv[1], sys.argv[2], float(sys.argv[3])
with open(path) as f: cfg = json.load(f)
away = cfg.get("awayRssi")
rearm = cfg.get("rearmRssi")
if which == "away":
    if rearm is not None and val >= rearm:
        print(f"[error] awayRssi ({val} dBm) must be less than rearmRssi ({rearm} dBm) — away is the 'farther' threshold", file=sys.stderr)
        print(f"        raise rearm first: farlock rearm-rssi <dBm greater than {val}>", file=sys.stderr)
        sys.exit(1)
    key = "awayRssi"
else:
    if away is not None and val <= away:
        print(f"[error] rearmRssi ({val} dBm) must be greater than awayRssi ({away} dBm) — rearm is the 'closer' threshold", file=sys.stderr)
        print(f"        lower away first: farlock away-rssi <dBm less than {val}>", file=sys.stderr)
        sys.exit(1)
    key = "rearmRssi"
old = cfg.get(key)
cfg[key] = val
with open(path, "w") as f: json.dump(cfg, f, indent=2)
print(f"{key}: {old} → {cfg[key]}")
PY
}

cmd_away_rssi() {
  if [ $# -eq 0 ]; then
    show_cfg awayRssi dBm
  else
    [[ "$1" =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || die "expected a dBm number (e.g. -60), got: $1"
    set_rssi away "$1" || exit $?
    reload_agent
    note "agent reloaded"
  fi
}

cmd_rearm_rssi() {
  if [ $# -eq 0 ]; then
    show_cfg rearmRssi dBm
  else
    [[ "$1" =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || die "expected a dBm number (e.g. -55), got: $1"
    set_rssi rearm "$1" || exit $?
    reload_agent
    note "agent reloaded"
  fi
}

# ---------- target -----------------------------------------------------------

cmd_target() {
  [ -x "$AGENT_BIN" ] || die "agent binary not found at $AGENT_BIN. Did you move the install directory?"
  require_config

  echo "Reading paired Bluetooth devices..."
  local paired_json
  paired_json=$(mktemp -t paired.XXXXXX).json
  trap 'rm -f "$paired_json" "${scan_json:-}"' EXIT
  system_profiler SPBluetoothDataType -json 2>/dev/null > "$paired_json" || true

  local list
  list=$(python3 - "$paired_json" <<'PY'
import json, sys
try:
    with open(sys.argv[1]) as f: d = json.load(f)
except Exception:
    sys.exit(0)
rows = []
for c in d.get("SPBluetoothDataType", []):
    for key in ("device_connected", "device_not_connected"):
        for e in c.get(key, []):
            if not isinstance(e, dict): continue
            for name, props in e.items():
                if not isinstance(props, dict): continue
                minor = props.get("device_minorType") or ""
                if ("Mac" in name or "MacBook" in name or "iMac" in name) and not minor:
                    continue
                rows.append((
                    name,
                    props.get("device_address") or "",
                    minor,
                    "1" if key == "device_connected" else "0",
                    str(props.get("device_rssi") or ""),
                ))
def sort_key(r):
    name, addr, minor, conn, rssi = r
    return (0 if conn == "1" else 1, 1 if minor else 0, name.lower())
for r in sorted(rows, key=sort_key):
    print("|".join(r))
PY
)
  [ -z "$list" ] && die "no paired Bluetooth devices found."

  echo
  printf "%sPaired Bluetooth devices:%s\n" "$BOLD" "$NC"
  local i=0
  while IFS='|' read -r name addr minor conn rssi; do
    i=$((i+1))
    local tags=""
    [ "$conn" = "1" ] && tags="connected"
    [ -n "$minor" ] && { [ -n "$tags" ] && tags="$tags, "; tags="${tags}${minor}"; }
    [ -n "$rssi" ]  && { [ -n "$tags" ] && tags="$tags, "; tags="${tags}rssi=${rssi}dBm"; }
    if [ -n "$tags" ]; then
      printf "  [%d] %-36s (%s)\n" "$i" "$name" "$tags"
    else
      printf "  [%d] %s\n" "$i" "$name"
    fi
  done <<< "$list"
  echo
  printf "%sEnter number%s: " "$BOLD" "$NC"
  read -r choice
  [[ "$choice" =~ ^[0-9]+$ ]] || die "not a number"
  local pick name mac
  pick=$(echo "$list" | sed -n "${choice}p")
  [ -n "$pick" ] || die "invalid selection"
  name=$(echo "$pick" | cut -d'|' -f1)
  mac=$(echo "$pick" | cut -d'|' -f2)

  # Try to capture UUID via a brief BLE scan. Stop the running LaunchAgent
  # first — two CoreBluetooth scans from the same user can interfere, and
  # the agent's active-mode connection may prevent discovery-mode reads.
  local scan_json uuid="" stopped_agent=0
  scan_json=$(mktemp -t proxscan.XXXXXX).json
  rm -f "$scan_json"
  if [ -f "$LAUNCH_AGENT" ] && pgrep -x Farlock >/dev/null; then
    launchctl bootout "gui/$(id -u)" "$LAUNCH_AGENT" 2>/dev/null || true
    stopped_agent=1
  fi
  echo "Scanning BLE to capture '$name' UUID (10 s)..."
  "$AGENT_BIN" --scan-only --output "$scan_json" >/dev/null 2>&1 &
  local pid=$!
  sleep 10
  kill "$pid" 2>/dev/null || true
  wait "$pid" 2>/dev/null || true
  if [ "$stopped_agent" = "1" ]; then
    launchctl bootstrap "gui/$(id -u)" "$LAUNCH_AGENT" 2>/dev/null || true
  fi
  if [ -s "$scan_json" ]; then
    uuid=$(python3 - "$scan_json" "$name" <<'PY'
import json, sys
with open(sys.argv[1]) as f: d = json.load(f)
name = sys.argv[2]
best = None
for u, e in d.get("devices", {}).items():
    if e.get("name") == name:
        if best is None or e.get("rssi", -999) > best[1]:
            best = (u, e.get("rssi", -999))
print(best[0] if best else "")
PY
)
  fi

  python3 - "$CONFIG_FILE" "$name" "$mac" "$uuid" <<'PY'
import json, sys
p, n, m, u = sys.argv[1:5]
with open(p) as f: cfg = json.load(f)
cfg["targetName"] = n
cfg["targetMacAddr"] = m or None
cfg["targetUuid"] = u or None
with open(p, "w") as f: json.dump(cfg, f, indent=2)
PY
  note "target: name='$name' mac='${mac:-?}' uuid='${uuid:-?}'"
  [ -z "$uuid" ] && warn "UUID not captured (iPhone may have been silent). Matching still works by name/MAC."
  reload_agent
  note "agent reloaded"
}

# ---------- list-paired ------------------------------------------------------

cmd_list_paired() {
  system_profiler SPBluetoothDataType -json 2>/dev/null | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(0)
rows = []
for c in d.get("SPBluetoothDataType", []):
    for k in ("device_connected", "device_not_connected"):
        for it in c.get(k, []):
            if isinstance(it, dict):
                for name, props in it.items():
                    if isinstance(props, dict):
                        rows.append((name,
                                     props.get("device_address",""),
                                     props.get("device_minorType",""),
                                     "connected" if k=="device_connected" else "",
                                     props.get("device_rssi","")))
w = max((len(r[0]) for r in rows), default=24)
for name, addr, minor, conn, rssi in rows:
    tags = ", ".join(x for x in [conn, minor, (f"rssi={rssi}dBm" if rssi else "")] if x)
    tag = f" ({tags})" if tags else ""
    print(f"  {name.ljust(w)}  {addr}{tag}")
'
}

# ---------- logs / reload / uninstall ---------------------------------------

cmd_logs() {
  [ -f "$LOG_FILE" ] || die "log file not found: $LOG_FILE"
  exec tail -F "$LOG_FILE"
}

cmd_reload() {
  [ -f "$LAUNCH_AGENT" ] || die "LaunchAgent not installed."
  launchctl kickstart -k "gui/$(id -u)/$AGENT_LABEL"
  note "agent reloaded"
}

cmd_uninstall() {
  [ -x "$INSTALL_DIR/uninstall.sh" ] || die "uninstall.sh not found at $INSTALL_DIR"
  exec "$INSTALL_DIR/uninstall.sh"
}

# ---------- dispatch ---------------------------------------------------------

[ $# -lt 1 ] && { usage; exit 0; }
case "$1" in
  status)                    shift; cmd_status ;;
  target)                    shift; cmd_target ;;
  away-rssi)                 shift; cmd_away_rssi "$@" ;;
  rearm-rssi)                shift; cmd_rearm_rssi "$@" ;;
  list-paired)               shift; cmd_list_paired ;;
  logs)                      shift; cmd_logs ;;
  reload)                    shift; cmd_reload ;;
  uninstall)                 shift; cmd_uninstall ;;
  -h|--help)                 usage ;;
  *) echo "Unknown command: $1" >&2; usage; exit 2 ;;
esac
